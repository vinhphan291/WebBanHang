@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@model IEnumerable<WebBanHang.Models.Product>

@{
    ViewData["Title"] = "Shop";
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username");
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var isLoggedIn = !string.IsNullOrEmpty(username);
    var searchString = ViewBag.SearchString as string;
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="searchString" class="form-control" placeholder="Nhập tên sản phẩm..." value="@searchString" />
        <button class="btn btn-outline-primary" type="submit">Tìm kiếm</button>
    </div>
</form>

<style>
    .product-card { border-radius: 12px; overflow: hidden; transition: 0.2s; background: #fff; }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
    .product-img { height: 200px; object-fit: cover; }
    .price { color: red; font-weight: bold; font-size: 18px; }
    .category { font-size: 13px; color: gray; }
    .btn-cart { width: 100%; border-radius: 20px; }
</style>

<h2 class="mb-4">🛒 Shop Products</h2>

@if (role == "Admin")
{
    <a asp-action="Create" class="btn btn-success mb-3">+ Create Product</a>
}

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="product-card shadow-sm">
                <img src="@item.ImageUrl" class="w-100 product-img" />
                <div class="p-3">
                    <h6>@item.Name</h6>
                    <div class="price">@item.Price.ToString("N0") đ</div>
                    <div class="category mb-2">@item.Category?.Name</div>

                    @if (isLoggedIn)
                    {
                        if (role == "Admin")
                        {
                            <button class="btn btn-secondary btn-cart" disabled>Admin không thể mua</button>
                        }
                        else
                        {
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <button type="submit" class="btn btn-success btn-cart">🛒 Thêm vào giỏ</button>
                            </form>
                        }
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-warning btn-cart">🔑 Đăng nhập để mua</a>
                    }

                    <!-- Nút Xem chi tiết -->
                    <div class="mt-2">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-cart">🔍 Xem chi tiết</a>
                    </div>

                    @if (role == "Admin")
                    {
                        <div class="mt-2 text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>