@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@model IEnumerable<WebBanHang.Models.Product>

@{
    ViewData["Title"] = "Shop";
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

<style>
    .product-card {
        border-radius: 12px;
        overflow: hidden;
        transition: 0.2s;
        background: #fff;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        }

    .product-img {
        height: 200px;
        object-fit: cover;
    }

    .price {
        color: red;
        font-weight: bold;
        font-size: 18px;
    }

    .category {
        font-size: 13px;
        color: gray;
    }

    .btn-cart {
        width: 100%;
        border-radius: 20px;
    }
</style>

<h2 class="mb-4">🛒 Shop Products</h2>

<!-- NÚT CREATE (CHỈ ADMIN THẤY) -->
@if (role == "Admin")
{
    <a asp-action="Create" class="btn btn-success mb-3">
        + Create Product
    </a>
}

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">

            <div class="product-card shadow-sm">

                <img src="@item.ImageUrl" class="w-100 product-img" />

                <div class="p-3">

                    <h6>@item.Name</h6>

                    <div class="price">
                        @item.Price.ToString("N0") đ
                    </div>

                    <div class="category mb-2">
                        @item.Category?.Name
                    </div>

                    <!-- ADD TO CART -->
                    <form asp-controller="Cart"
                          asp-action="AddToCart"
                          method="post">

                        <input type="hidden" name="productId" value="@item.Id" />

                        <button type="submit" class="btn btn-success btn-cart">
                            🛒 Add to Cart
                        </button>
                    </form>

                    <!-- ADMIN BUTTON -->
                    @if (role == "Admin")
                    {
                        <div class="mt-2 text-center">

                            <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>
    }

</div>