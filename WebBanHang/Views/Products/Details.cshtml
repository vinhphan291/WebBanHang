@model WebBanHang.Models.Product
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username");
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var isLoggedIn = !string.IsNullOrEmpty(username);
}

<h1>Chi tiết sản phẩm</h1>

<div>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid" style="max-height: 400px; object-fit: contain;" alt="@Model.Name">
        </div>
        <div class="col-md-6">
            <h2>@Model.Name</h2>
            <p class="text-muted">Danh mục: @Model.Category?.Name</p>
            <p>@Model.Description</p>
            <h3 class="text-danger">@Model.Price.ToString("N0") đ</h3>
            @if (Model.StockQuantity > 0)
            {
                <p class="text-success">Còn hàng: @Model.StockQuantity sản phẩm</p>
            }
            else
            {
                <p class="text-danger">Hết hàng</p>
            }

            <!-- Xử lý nút mua hàng -->
            @if (isLoggedIn)
            {
                if (role == "Admin")
                {
                    <div class="mt-3">
                        <button class="btn btn-secondary btn-lg" disabled>Admin không thể mua hàng</button>
                    </div>
                }
                else
                {
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-3">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                        </button>
                    </form>
                }
            }
            else
            {
                <div class="mt-3">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-warning btn-lg">
                        🔑 Đăng nhập để mua
                    </a>
                </div>
            }

            <!-- Nút Edit/Delete cho admin -->
            @if (role == "Admin")
            {
                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Xóa</a>
                </div>
            }

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>

            <!-- Phần đánh giá -->
            <div class="mt-5">
                <h4>Đánh giá sản phẩm</h4>
                @{
                    var reviews = ViewBag.Reviews as List<WebBanHang.Models.ProductReview>;
                    if (reviews != null && reviews.Any())
                    {
                        foreach (var review in reviews)
                        {
                            <div class="border-bottom mb-3 pb-2">
                                <strong>@review.UserName</strong>
                                <span class="text-warning">
                                    @for (int i = 0; i < review.Rating; i++)
                                    {
                                        <span>★</span>
                                    }
                                    @for (int i = review.Rating; i < 5; i++)
                                    {
                                        <span>☆</span>
                                    }
                                </span>
                                <span class="text-muted small">@review.CreatedAt.ToString("dd/MM/yyyy")</span>
                                <p>@review.Comment</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p>Chưa có đánh giá nào.</p>
                    }
                }

                @if (isLoggedIn && role != "Admin")
                {
                    <form asp-action="AddReview" method="post" class="mt-3">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="mb-2">
                            <label>Đánh giá sao:</label>
                            <select name="rating" class="form-select w-auto">
                                <option value="5">★★★★★ (5 sao)</option>
                                <option value="4">★★★★☆ (4 sao)</option>
                                <option value="3">★★★☆☆ (3 sao)</option>
                                <option value="2">★★☆☆☆ (2 sao)</option>
                                <option value="1">★☆☆☆☆ (1 sao)</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label>Nhận xét:</label>
                            <textarea name="comment" class="form-control" rows="3"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>