@model WebBanHang.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="alert alert-success">
    <h2>Cảm ơn bạn đã đặt hàng!</h2>
    <p>Mã đơn hàng: <strong>@Model.Id</strong></p>
</div>
<div class="card">
    <div class="card-header">Thông tin đơn hàng</div>
    <div class="card-body">
        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Người nhận:</strong> @Model.CustomerName</p>
        <p><strong>Số điện thoại:</strong> @Model.Phone</p>
        <p><strong>Địa chỉ:</strong> @Model.Address</p>
        <p><strong>Phương thức thanh toán:</strong> @(Model.PaymentMethod == "COD" ? "COD" : "Chuyển khoản")</p>
        <p><strong>Tổng tiền:</strong> <span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") đ</span></p>
    </div>
</div>
<div class="mt-3"><a asp-controller="Products" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a></div>