@model List<WebBanHang.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2>Giỏ hàng của bạn</h2>

@if (!Model.Any())
{
    <p>Giỏ hàng trống.</p>
    <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr><th>Ảnh</th><th>Sản phẩm</th><th>Giá</th><th>Số lượng</th><th>Thành tiền</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><img src="@item.ImageUrl" width="60" /></td>
                    <td>@item.ProductName</td>
                    <td>@item.Price.ToString("N0") đ</td>
                    <td>
                        <form asp-action="UpdateCart" method="post" style="display:inline;">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" style="width:60px;" />
                            <button type="submit" class="btn btn-sm btn-primary">Cập nhật</button>
                        </form>
                    </td>
                    <td>@((item.Price * item.Quantity).ToString("N0")) đ</td>
                    <td><a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="btn btn-sm btn-danger">Xóa</a></td>
                </tr>
            }
        </tbody>
        <tfoot><tr><td colspan="4" class="text-end fw-bold">Tổng cộng:</td><td class="fw-bold">@Model.Sum(x => x.Price * x.Quantity).ToString("N0") đ</td><td></td></tr></tfoot>
    </table>
    <div class="text-end">
        <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">Tiếp tục mua sắm</a>
        <a asp-action="Checkout" class="btn btn-success">Thanh toán</a>
    </div>
}