@model IEnumerable<WebBanHang.Models.Order>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Danh sách đơn hàng</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        h2 { text-align: center; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
    </style>
</head>
<body>
    <h2>Danh sách đơn hàng</h2>
    <p><strong>Ngày xuất:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    <table>
        <thead>
            <tr><th>Mã đơn</th><th>Ngày đặt</th><th>Khách hàng</th><th>SĐT</th><th>Địa chỉ</th><th>Tổng tiền</th><th>Trạng thái</th></tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@order.CustomerName</td>
                    <td>@order.Phone</td>
                    <td>@order.Address</td>
                    <td>@order.TotalAmount.ToString("N0") đ</td>
                    <td>@order.OrderStatus</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>