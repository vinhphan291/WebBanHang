@model IEnumerable<WebBanHang.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng (Admin)";
    var role = Context.Session.GetString("Role");
}

@if (role != "Admin")
{
    <p>Bạn không có quyền truy cập.</p>
    return;
}

<h2>Quản lý đơn hàng</h2>

<div class="mb-3">
    <a asp-action="ExportToExcel" class="btn btn-success">Xuất Excel</a>
    <a asp-action="ExportToPdf" class="btn btn-danger">Xuất PDF</a>
</div>

<table class="table table-hover">
    <thead><tr><th>Mã đơn</th><th>Người đặt</th><th>Ngày đặt</th><th>Tổng tiền</th><th>Trạng thái</th><th></th></tr></thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.CustomerName (@order.UserName)</td>
                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@order.TotalAmount.ToString("N0") đ</td>
                <td>
                    @switch (order.OrderStatus)
                    {
                        case "Pending":
                            <span class="badge bg-warning">Chờ xác nhận</span>
                            ; break;
                        case "Confirmed":

                            <span class="badge bg-info">Đã xác nhận</span>
                            ; break;
                        case "Shipped":

                            <span class="badge bg-primary">Đang giao</span>
                            ; break;
                        case "Delivered":

                            <span class="badge bg-success">Đã giao</span>
                            ; break;
                        case "Cancelled":

                            <span class="badge bg-danger">Đã hủy</span>
                            ; break;
                        default:

                            <span class="badge bg-secondary">@order.OrderStatus</span>
                            ; break;
                    }
                </td>
                <td><a asp-action="AdminDetails" asp-route-id="@order.Id" class="btn btn-sm btn-info">Chi tiết</a></td>
            </tr>
        }
    </tbody>
</table>