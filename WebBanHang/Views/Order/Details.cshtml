@model WebBanHang.Models.Order
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Id}";
}

<h2>Chi tiết đơn hàng #@Model.Id</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-3">
    <div class="card-header bg-primary text-white">Thông tin chung</div>
    <div class="card-body">
        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Người nhận:</strong> @Model.CustomerName</p>
        <p><strong>Số điện thoại:</strong> @Model.Phone</p>
        <p><strong>Địa chỉ:</strong> @Model.Address</p>
        <p><strong>Thanh toán:</strong> @(Model.PaymentMethod == "COD" ? "COD" : "Chuyển khoản")</p>
        <p>
            <strong>Trạng thái:</strong>
            @switch (Model.OrderStatus)
            {
                case "Pending":
                    <span class="badge bg-warning">Chờ xác nhận</span>
                    ; break;
                case "Confirmed":

                    <span class="badge bg-info">Đã xác nhận</span>
                    ; break;
                case "Shipped":

                    <span class="badge bg-primary">Đang giao</span>
                    ; break;
                case "Delivered":

                    <span class="badge bg-success">Đã giao</span>
                    ; break;
                case "Cancelled":

                    <span class="badge bg-danger">Đã hủy</span>
                    ; break;
                default:

                    <span class="badge bg-secondary">@Model.OrderStatus</span>
                    ; break;
            }
        </p>
        <p><strong>Tổng tiền:</strong> <span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") đ</span></p>
    </div>
</div>

<h4>Sản phẩm đã mua</h4>
<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>Sản phẩm</th>
            <th>Đơn giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var detail in Model.OrderDetails)
        {
            <tr>
                <td>@detail.Product?.Name</td>
                <td>@detail.UnitPrice.ToString("N0") đ</td>
                <td>@detail.Quantity</td>
                <td>@((detail.UnitPrice * detail.Quantity).ToString("N0")) đ</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    @if (Model.OrderStatus == "Pending")
    {
        <form asp-action="Cancel" method="post" style="display:inline;">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger" onclick="return confirm('Bạn chắc chắn muốn hủy đơn hàng này?');">Hủy đơn hàng</button>
        </form>
    }
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>