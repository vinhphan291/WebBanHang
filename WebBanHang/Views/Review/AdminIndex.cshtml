@model IEnumerable<WebBanHang.Models.ProductReview>
@{
    ViewData["Title"] = "Quản lý đánh giá";
    var role = Context.Session.GetString("Role");
}

@if (role != "Admin")
{
    <p>Bạn không có quyền truy cập.</p>
    return;
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<h2>Quản lý đánh giá sản phẩm</h2>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Người dùng</th>
            <th>Rating</th>
            <th>Nhận xét</th>
            <th>Ngày</th>
            <th></th>
        </thead>
        <tbody>
            @foreach (var review in Model)
            {
                <tr>
                    <td>@review.Product?.Name</td>
                    <td>@review.UserName</td>
                    <td>
                        @for (int i = 0; i < review.Rating; i++)
                        {
                            <span>★</span>
                        }
                        @for (int i = review.Rating; i < 5; i++)
                        {
                            <span>☆</span>
                        }
                    </td>
                    <td>@review.Comment</td>
                    <td>@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <form asp-action="Delete" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@review.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa đánh giá này?');">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>